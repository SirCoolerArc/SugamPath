    { "id": "render", "type": "rectangle", "x": 300, "y": 942, "width": 500, "height": 120, "strokeColor": "#1e1e1e", "backgroundColor": "#ffffff", "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100, "angle": 0, "roundness": {"type": 3}, "seed": 120 },
    { "id": "render-label", "type": "text", "x": 315, "y": 952, "width": 470, "height": 100, "text": "4. Render & Reconstruct\napplyCriticalFieldSubstitution · PII tokens → real values\nISL chip resolution (10,243 ISLRTC entries)\nAction items panel · safety badges", "fontSize": 12, "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "opacity": 100, "angle": 0, "seed": 121 },
