    { "id": "label-box-resimplify", "type": "text", "x": 30, "y": 430, "width": 180, "height": 90, "text": "/api/resimplify\nsimplify(level, lang)\n→ faithfulness → render\nCache hit = instant swap", "fontSize": 11, "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "opacity": 100, "angle": 0, "seed": 31 },
