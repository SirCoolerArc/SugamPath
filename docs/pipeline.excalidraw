    { "id": "isl-col-label", "type": "text", "x": 1092, "y": 252, "width": 256, "height": 516, "text": "ISL Proxy\n\nGET /api/isl-dictionary\nRewrites Drive URLs\n→ /api/isl-video/<fileId>\n10,243 entries\n\nGET /api/isl-video/<fileId>\nPipes Drive bytes through origin\nAPI key server-only\nCORS solved\n\nPlay-all sequencer\nlib/isl_sequencer.ts\nWalks chips in document order\nFloating player\nSync text highlight", "fontSize": 12, "fontFamily": 2, "textAlign": "center", "verticalAlign": "top", "strokeColor": "#15803d", "backgroundColor": "transparent", "fillStyle": "solid", "opacity": 100, "angle": 0, "seed": 151 },
