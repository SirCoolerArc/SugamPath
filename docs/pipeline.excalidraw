    { "id": "response-bar-label", "type": "text", "x": 315, "y": 1132, "width": 470, "height": 30, "text": "Response → Browser (simplified text · ISL chips · action items · safety badges)", "fontSize": 12, "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "opacity": 100, "angle": 0, "seed": 141 },
