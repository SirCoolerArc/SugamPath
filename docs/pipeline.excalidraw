    { "id": "label-box-query", "type": "text", "x": 910, "y": 430, "width": 180, "height": 90, "text": "/api/query\nVision → one-shot answer\nRefuses advice\nAnswers in asker's language", "fontSize": 11, "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "opacity": 100, "angle": 0, "seed": 33 },
    { "id": "extract", "type": "rectangle", "x": 300, "y": 240, "width": 500, "height": 120, "strokeColor": "#1e1e1e", "backgroundColor": "#ffffff", "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100, "angle": 0, "roundness": {"type": 3}, "seed": 40 },
    { "id": "extract-label", "type": "text", "x": 315, "y": 252, "width": 470, "height": 96, "text": "1. Extract\nVision pass over document images\nEmits typed JSON: paragraphs, critical_fields, action_items, pii_spans\nprompt: extract.md · Zod validation · retry ×2 on schema failure", "fontSize": 12, "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "opacity": 100, "angle": 0, "seed": 41 },
    { "id": "arrow-post-extract", "type": "arrow", "x": 550, "y": 360, "width": 0, "height": 70, "points": [[0,0],[0,70]], "strokeColor": "#1e1e1e", "strokeWidth": 3, "fillStyle": "solid", "backgroundColor": "transparent", "startArrowhead": null, "endArrowhead": "arrow", "opacity": 100, "angle": 0, "seed": 42 },
    { "id": "label-post-extract", "type": "text", "x": 565, "y": 385, "width": 180, "height": 20, "text": "tokenised extraction", "fontSize": 11, "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "opacity": 100, "angle": 0, "seed": 43 },
    { "id": "badge-pii", "type": "rectangle", "x": 820, "y": 255, "width": 260, "height": 175, "strokeColor": "#92400e", "backgroundColor": "#fef3c7", "fillStyle": "solid", "strokeWidth": 1.5, "roughness": 0, "opacity": 100, "angle": 0, "roundness": {"type": 3}, "seed": 50 },
    { "id": "badge-pii-label", "type": "text", "x": 830, "y": 263, "width": 240, "height": 159, "text": "🔒 PII Vault\nPass 1: 16 regex patterns\n(Latin + Devanagari label cues)\nPass 2: LLM pii_spans merged\nTokens: [NAME_001], [AADHAAR_001]…\nMap scoped to request closure\nNever logged · never sent to client", "fontSize": 11, "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "strokeColor": "#92400e", "backgroundColor": "transparent", "fillStyle": "solid", "opacity": 100, "angle": 0, "seed": 51 },
