    { "id": "badge-lock", "type": "rectangle", "x": 300, "y": 562, "width": 310, "height": 110, "strokeColor": "#92400e", "backgroundColor": "#fef3c7", "fillStyle": "solid", "strokeWidth": 1.5, "roughness": 0, "opacity": 100, "angle": 0, "roundness": {"type": 3}, "seed": 70 },
    { "id": "badge-lock-label", "type": "text", "x": 310, "y": 570, "width": 290, "height": 94, "text": "🔐 Critical-field lock\nSubstitution runs in code after LLM\n{{c1}} → <span>Aspirin 75mg, once daily</span>\nLLM cannot paraphrase a dose\nStructural — not prompted", "fontSize": 11, "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "strokeColor": "#92400e", "backgroundColor": "transparent", "fillStyle": "solid", "opacity": 100, "angle": 0, "seed": 71 },
    { "id": "badge-injection", "type": "rectangle", "x": 640, "y": 562, "width": 260, "height": 110, "strokeColor": "#92400e", "backgroundColor": "#fef3c7", "fillStyle": "solid", "strokeWidth": 1.5, "roughness": 0, "opacity": 100, "angle": 0, "roundness": {"type": 3}, "seed": 72 },
    { "id": "badge-injection-label", "type": "text", "x": 650, "y": 570, "width": 240, "height": 94, "text": "🛡 Adversarial defence\nSeparate guardrail call\nIndependent of simplification\nSUSPICIOUS → rust-accent\nbanner shown in UI", "fontSize": 11, "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "strokeColor": "#92400e", "backgroundColor": "transparent", "fillStyle": "solid", "opacity": 100, "angle": 0, "seed": 73 },
    { "id": "arrow-to-faith", "type": "arrow", "x": 455, "y": 672, "width": 0, "height": 70, "points": [[0,0],[0,70]], "strokeColor": "#1e1e1e", "strokeWidth": 3, "fillStyle": "solid", "backgroundColor": "transparent", "startArrowhead": null, "endArrowhead": "arrow", "opacity": 100, "angle": 0, "seed": 80 },
    { "id": "label-to-faith", "type": "text", "x": 468, "y": 693, "width": 220, "height": 20, "text": "post-substitution simplification", "fontSize": 11, "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "opacity": 100, "angle": 0, "seed": 81 },
    { "id": "faithfulness", "type": "rectangle", "x": 300, "y": 742, "width": 500, "height": 130, "strokeColor": "#1e1e1e", "backgroundColor": "#ffffff", "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100, "angle": 0, "roundness": {"type": 3}, "seed": 90 },
    { "id": "faithfulness-label", "type": "text", "x": 315, "y": 752, "width": 470, "height": 110, "text": "3. Faithfulness Judge\nprompt: faithfulness.md\nAudits simplification's critical fields against extraction's\nVerdict: VERIFIED | VERIFIED_WITH_OMISSIONS | UNVERIFIED\nLanguage-aware (Hindi paraphrases not false-flagged)", "fontSize": 12, "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "opacity": 100, "angle": 0, "seed": 91 },
    { "id": "badge-faith", "type": "rectangle", "x": 820, "y": 742, "width": 260, "height": 170, "strokeColor": "#92400e", "backgroundColor": "#fef3c7", "fillStyle": "solid", "strokeWidth": 1.5, "roughness": 0, "opacity": 100, "angle": 0, "roundness": {"type": 3}, "seed": 100 },
    { "id": "badge-faith-label", "type": "text", "x": 830, "y": 750, "width": 240, "height": 154, "text": "⚖️ Faithfulness check\nSystem second-guesses itself\nUNVERIFIED → retry simplifier\nwith judge findings as guidance\nSecond pass re-judged\nFinal verdict shown in safety badge", "fontSize": 11, "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "strokeColor": "#92400e", "backgroundColor": "transparent", "fillStyle": "solid", "opacity": 100, "angle": 0, "seed": 101 },
