    { "id": "simplify", "type": "rectangle", "x": 300, "y": 430, "width": 310, "height": 120, "strokeColor": "#1e1e1e", "backgroundColor": "#ffffff", "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100, "angle": 0, "roundness": {"type": 3}, "seed": 60 },
    { "id": "simplify-label", "type": "text", "x": 312, "y": 440, "width": 286, "height": 98, "text": "2a. Simplify\nprompt: simplify.md\nEmits {{cN}} placeholders\nLLM never sees verbatim values\nLevel + language appended at runtime", "fontSize": 12, "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "opacity": 100, "angle": 0, "seed": 61 },
    { "id": "injection", "type": "rectangle", "x": 640, "y": 430, "width": 260, "height": 120, "strokeColor": "#1e1e1e", "backgroundColor": "#ffffff", "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100, "angle": 0, "roundness": {"type": 3}, "seed": 62 },
    { "id": "injection-label", "type": "text", "x": 652, "y": 440, "width": 236, "height": 98, "text": "2b. Injection Check\nprompt: injection_check.md\nVerdict: CLEAN | SUSPICIOUS\nFlags adversarial directives\naimed at the model", "fontSize": 12, "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "opacity": 100, "angle": 0, "seed": 63 },
